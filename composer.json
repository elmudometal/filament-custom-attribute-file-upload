{
    "name": "elmudo-dev/filament-custom-attribute-file-upload",
    "description": "Component to add a custom name to image attributes for captions",
    "keywords": [
        "Elmudo-Dev",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-custom-attribute-file-upload"
    ],
    "homepage": "https://github.com/elmudo-dev/filament-custom-attribute-file-upload",
    "support": {
        "issues": "https://github.com/elmudo-dev/filament-custom-attribute-file-upload/issues",
        "source": "https://github.com/elmudo-dev/filament-custom-attribute-file-upload"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Hernan Soto",
            "email": "elmudometal@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/forms": "^4.0|^5.0",
        "filament/spatie-laravel-media-library-plugin": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^11.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0",
        "spatie/laravel-ray": "^1.26"
    },
    "autoload": {
        "psr-4": {
            "ElmudoDev\\FilamentCustomAttributeFileUpload\\": "src/",
            "ElmudoDev\\FilamentCustomAttributeFileUpload\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ElmudoDev\\FilamentCustomAttributeFileUpload\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "ElmudoDev\\FilamentCustomAttributeFileUpload\\FilamentCustomAttributeFileUploadServiceProvider"
            ],
            "aliases": {
                "FilamentCustomAttributeFileUpload": "ElmudoDev\\FilamentCustomAttributeFileUpload\\Facades\\FilamentCustomAttributeFileUpload"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
